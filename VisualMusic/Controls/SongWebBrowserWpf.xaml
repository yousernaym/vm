<UserControl x:Class="VisualMusic.Controls.SongWebBrowserWpf"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ToolBar Grid.Row="0">
            <Button x:Name="backButton"    Content="&#x2190;" Width="28" IsEnabled="False" Click="BackButtonClick"/>
            <Button x:Name="forwardButton" Content="&#x2192;" Width="28" IsEnabled="False" Click="ForwardButtonClick"/>
            <TextBox x:Name="urlTextBox"   MinWidth="400" VerticalAlignment="Center" KeyUp="UrlTextBoxKeyUp"/>
            <Button x:Name="goButton"      Content="Go"         Width="40" Click="GoButtonClick"/>
        </ToolBar>

        <!-- ChromiumWebBrowser is added in code-behind to avoid XAML compiler dependency on CefSharp.Wpf -->
        <Grid x:Name="browserContainer" Grid.Row="1"/>

        <TextBlock x:Name="statusLabel" Grid.Row="2" Padding="4,2" FontSize="11"/>
    </Grid>
</UserControl>
