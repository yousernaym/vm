<UserControl x:Class="VisualMusic.Controls.Tabs.AudioTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="4">
        <TextBlock Text="Audio file" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBox Text="{Binding AudioFilename, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                 Margin="0,0,0,4"/>
        <Button Content="Browse..." HorizontalAlignment="Left"
                Width="72" Click="BrowseBtn_Click"/>
        <TextBlock Text="Silence threshold (s)" FontWeight="SemiBold" Margin="0,12,0,4"/>
        <TextBox Text="{Binding SilenceThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 Width="72" HorizontalAlignment="Left"
                 ToolTip="Hide this track's waveform when it will be silent for this many seconds. Empty = use the global track's value."/>
    </StackPanel>
</UserControl>
