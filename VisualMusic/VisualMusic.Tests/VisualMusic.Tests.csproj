<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0-windows10.0.26100.0</TargetFramework>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <IsPackable>false</IsPackable>
    <PlatformTarget>x64</PlatformTarget>
    <UseWPF>true</UseWPF>
    <RootNamespace>VisualMusic.Tests</RootNamespace>
  </PropertyGroup>

  <!-- Shared native-runtime paths (vcpkg_installed + x64\<Config>\); see NativePaths.props. -->
  <Import Project="..\..\NativePaths.props" />

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.14.1" />
    <PackageReference Include="xunit" Version="2.9.3" />
    <PackageReference Include="xunit.runner.visualstudio" Version="3.1.4">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <!--
      Same global properties as the sln's VisualMusic build (no AdditionalProperties) so MSBuild
      shares one project instance / output. CopyNativeOutputs soft-skips when natives are absent.
    -->
    <ProjectReference Include="..\VisualMusic.csproj" />
  </ItemGroup>

  <!-- Fixtures live in owning submodules; flatten into output test-files/ (PreserveNewest). -->
  <ItemGroup>
    <None Include="..\..\Dependencies\midiLib\test-files\**\*" LinkBase="test-files" CopyToOutputDirectory="PreserveNewest" />
    <None Include="..\..\Dependencies\Media\test-files\**\*" LinkBase="test-files" CopyToOutputDirectory="PreserveNewest" />
    <None Include="..\..\Dependencies\MidMix\test-files\**\*" LinkBase="test-files" CopyToOutputDirectory="PreserveNewest" />
    <None Include="..\..\Dependencies\Remuxer\libRemuxer\test-files\**\*" LinkBase="test-files" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <!--
    After a VisualMusic.sln Any CPU build (natives still under x64\<Config>\), make $(TargetDir)
    a complete native runtime dir for Media/MidMix Integration tests. Unit-only builds skip cleanly.
  -->

  <Target Name="CopyNativeRuntimeForIntegration" AfterTargets="Build">
    <PropertyGroup>
      <_HasSlnNatives Condition="Exists('$(_SlnNativeOut)media.dll') and Exists('$(_SlnNativeOut)MidMix.dll')">true</_HasSlnNatives>
    </PropertyGroup>

    <!-- Third-party FFmpeg/Fluidsynth DLLs from the canonical vcpkg_installed trees. -->
    <ItemGroup Condition="'$(_HasSlnNatives)'=='true' and Exists('$(_MediaVcpkgBin)')">
      <_NativeDlls Include="$(_MediaVcpkgBin)*.dll" />
    </ItemGroup>
    <ItemGroup Condition="'$(_HasSlnNatives)'=='true' and Exists('$(_MidMixVcpkgBin)')">
      <_NativeDlls Include="$(_MidMixVcpkgBin)*.dll" />
    </ItemGroup>
    <!-- Solution outputs last so freshly built media.dll / MidMix.dll win. -->
    <ItemGroup Condition="'$(_HasSlnNatives)'=='true'">
      <_NativeDlls Include="$(_SlnNativeOut)*.dll" />
    </ItemGroup>

    <Copy SourceFiles="@(_NativeDlls)" DestinationFolder="$(TargetDir)" SkipUnchangedFiles="true"
          Condition="'$(_HasSlnNatives)'=='true' and '@(_NativeDlls)'!=''" />

    <PropertyGroup Condition="'$(_HasSlnNatives)'=='true'">
      <_MissingNative Condition="!Exists('$(TargetDir)media.dll')">media.dll</_MissingNative>
      <_MissingNative Condition="'$(_MissingNative)'=='' and !Exists('$(TargetDir)MidMix.dll')">MidMix.dll</_MissingNative>
    </PropertyGroup>

    <!-- Glob checks for versioned dependency DLLs -->
    <ItemGroup Condition="'$(_HasSlnNatives)'=='true'">
      <_FluidsynthDll Include="$(TargetDir)libfluidsynth-*.dll" />
      <_AvcodecDll Include="$(TargetDir)avcodec-*.dll" />
      <_AvformatDll Include="$(TargetDir)avformat-*.dll" />
      <_AvutilDll Include="$(TargetDir)avutil-*.dll" />
      <_SwscaleDll Include="$(TargetDir)swscale-*.dll" />
      <_SwresampleDll Include="$(TargetDir)swresample-*.dll" />
      <_Libx264Dll Include="$(TargetDir)libx264-*.dll" />
    </ItemGroup>
    <PropertyGroup Condition="'$(_HasSlnNatives)'=='true'">
      <_MissingNative Condition="'$(_MissingNative)'=='' and '@(_FluidsynthDll)'==''">libfluidsynth-*.dll</_MissingNative>
      <_MissingNative Condition="'$(_MissingNative)'=='' and '@(_AvcodecDll)'==''">avcodec-*.dll</_MissingNative>
      <_MissingNative Condition="'$(_MissingNative)'=='' and '@(_AvformatDll)'==''">avformat-*.dll</_MissingNative>
      <_MissingNative Condition="'$(_MissingNative)'=='' and '@(_AvutilDll)'==''">avutil-*.dll</_MissingNative>
      <_MissingNative Condition="'$(_MissingNative)'=='' and '@(_SwscaleDll)'==''">swscale-*.dll</_MissingNative>
      <_MissingNative Condition="'$(_MissingNative)'=='' and '@(_SwresampleDll)'==''">swresample-*.dll</_MissingNative>
      <_MissingNative Condition="'$(_MissingNative)'=='' and '@(_Libx264Dll)'==''">libx264-*.dll</_MissingNative>
    </PropertyGroup>

    <Error Condition="'$(_HasSlnNatives)'=='true' and '$(_MissingNative)'!=''"
           Text="VisualMusic.Tests native runtime incomplete in $(TargetDir): missing $(_MissingNative). Build VisualMusic.sln Debug|Any CPU (or matching Configuration) so media.dll and MidMix.dll are under x64\$(Configuration)\ and FFmpeg/Fluidsynth DLLs are restored under Dependencies\Media\vcpkg_installed\ / Dependencies\MidMix\vcpkg_installed\." />

    <Message Importance="high"
             Condition="'$(_HasSlnNatives)'!='true'"
             Text="VisualMusic.Tests: skipped native runtime copy (no $(_SlnNativeOut)media.dll + MidMix.dll). Unit tests are fine; Integration tests need a prior VisualMusic.sln Any CPU build." />
  </Target>

</Project>
