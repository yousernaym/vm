<UserControl x:Class="VisualMusic.Controls.Tabs.AudioTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:VisualMusic.Controls"
             xmlns:kf="clr-namespace:VisualMusic.Keyframes">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
    </UserControl.Resources>
    <StackPanel Margin="4">
        <Button Content="_Default Audio" HorizontalAlignment="Left" Margin="0,0,0,6" Click="DefaultAudioBtn_Click"/>
        <!-- Normal selection: single audio file for the selected track(s) -->
        <StackPanel Visibility="{Binding IsNotOnlyGlobalSelected, Converter={StaticResource BoolVis}}">
            <TextBlock Text="Audio file path" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox Text="{Binding AudioFilename, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                     Margin="0,0,0,4"/>
            <StackPanel Orientation="Horizontal">
                <Button Content="Bro_wse..." Width="72" Click="BrowseBtn_Click"/>
                <Button Content="_Clear" Width="72" Margin="4,0,0,0" Click="RemoveBtn_Click"
                        ToolTip="Clear the audio file path of the selected track(s)."/>
            </StackPanel>
            <TextBlock Text="Label" FontWeight="SemiBold" Margin="0,12,0,4"/>
            <TextBox Text="{Binding Label, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                     Margin="0,0,0,4"
                     ToolTip="Text drawn above this track's waveform. Leave blank for no label."/>
        </StackPanel>
        <!-- Global-only selection: batch assignment across all tracks -->
        <StackPanel Visibility="{Binding IsOnlyGlobalSelected, Converter={StaticResource BoolVis}}">
            <TextBlock Text="Audio files" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <Button Content="Assi_gn audio files..." HorizontalAlignment="Left"
                    Click="AssignBtn_Click"
                    ToolTip="Pick multiple audio files and assign them to tracks."/>
        </StackPanel>
        <TextBlock Text="Silence threshold (s)" FontWeight="SemiBold" Margin="0,12,0,4"/>
        <ctrl:TbSliderWpf Margin="2"
                          Value="{Binding SilenceThreshold, Mode=TwoWay}"
                          Min="0" Max="10" Decimals="1" SmallChange="1"
                          AllowEmpty="True"
                          ToolTip="Hide this track's waveform when it will be silent for this many seconds. Empty = use the global track's value."
                          kf:Keyframing.PropertyId="SilenceThreshold"
                          kf:Keyframing.Scope="{x:Static kf:KeyframeService+KfScope.Track}"
                          kf:Keyframing.Interpolatable="True"/>

        <TextBlock Text="Waveform view width (ms)" FontWeight="SemiBold" Margin="0,12,0,4"/>
        <ctrl:TbSliderWpf Margin="2"
                          Value="{Binding WaveformViewWidthMs, Mode=TwoWay}"
                          Min="1" Max="100" Decimals="1" SmallChange="1"
                          AllowEmpty="True"
                          ToolTip="Waveform time window in milliseconds (horizontal zoom): smaller = zoom in, larger = zoom out. Empty = use the global track's value."
                          kf:Keyframing.PropertyId="WaveformViewWidthMs"
                          kf:Keyframing.Scope="{x:Static kf:KeyframeService+KfScope.Track}"
                          kf:Keyframing.Interpolatable="True"/>

        <TextBlock Text="Trigger sync" FontWeight="SemiBold" Margin="0,12,0,4"/>
        <ComboBox Margin="2" SelectedIndex="{Binding TriggerAlgorithmIndex, Mode=TwoWay}"
                  ToolTip="Oscilloscope trigger algorithm that steadies the waveform. Default = use the global track's setting (whose Default is Peak speed)."
                  kf:Keyframing.PropertyId="TriggerAlgorithmIndex"
                  kf:Keyframing.Scope="{x:Static kf:KeyframeService+KfScope.Track}"
                  kf:Keyframing.Interpolatable="False">
            <ComboBoxItem Content="Default"
                          ToolTip="Use the global track's setting. On the global track itself this selects Peak speed."/>
            <ComboBoxItem Content="Peak speed"
                          ToolTip="Locks to a rising zero crossing followed by a near-maximal peak, preferring the one that keeps the view advancing smoothly. Stays stable even when the wave crosses zero several times per cycle — a good general-purpose default."/>
            <ComboBoxItem Content="Rising edge"
                          ToolTip="Classic oscilloscope trigger: the first negative-to-positive zero crossing. Good for clean, simple waveforms (square/pulse, triangle); can jitter on waves with multiple zero crossings per cycle."/>
            <ComboBoxItem Content="Auto-correlation"
                          ToolTip="Aligns each frame with the previous one for maximum similarity. Best for complex, detuned or slowly-evolving sounds where edge triggers jump around; the most CPU-intensive option."/>
            <ComboBoxItem Content="Widest wave"
                          ToolTip="Locks to the widest full cycle in view — good for steady low-pitched tones. Volume changes on noise channels can fool it."/>
            <ComboBoxItem Content="Middle widest"
                          ToolTip="SidWiz's classic 'alternate' algorithm: like Widest wave, but when several cycles tie it centers on the middle one, which reduces hopping."/>
            <ComboBoxItem Content="Biggest wave area"
                          ToolTip="Locks to the cycle with the largest total area (positive + negative). Favors the loudest cycle; useful for percussive or uneven material."/>
            <ComboBoxItem Content="Biggest positive area"
                          ToolTip="Locks to the cycle with the largest positive area. Like Biggest wave area but biased toward the positive half — can help strongly asymmetric waveforms."/>
            <ComboBoxItem Content="None"
                          ToolTip="No synchronization; the waveform scrolls freely. Best for drums and noise, where any trigger just jitters."/>
        </ComboBox>

        <TextBlock Text="Trigger lookahead (frames)" FontWeight="SemiBold" Margin="0,12,0,4"/>
        <ctrl:TbSliderWpf Margin="2"
                          Value="{Binding TriggerLookaheadFrames, Mode=TwoWay}"
                          Min="0" Max="8" Decimals="0" SmallChange="1"
                          AllowEmpty="True"
                          ToolTip="Frames the trigger may look ahead to find a stable sync point; helps low-frequency (bass) channels. Empty = use the global track's value (default 1)."
                          kf:Keyframing.PropertyId="TriggerLookahead"
                          kf:Keyframing.Scope="{x:Static kf:KeyframeService+KfScope.Track}"
                          kf:Keyframing.Interpolatable="False"/>

        <TextBlock Text="Trigger lookahead on failure (frames)" FontWeight="SemiBold" Margin="0,12,0,4"/>
        <ctrl:TbSliderWpf Margin="2"
                          Value="{Binding TriggerLookaheadOnFailureFrames, Mode=TwoWay}"
                          Min="0" Max="8" Decimals="0" SmallChange="1"
                          AllowEmpty="True"
                          ToolTip="Extra frames searched beyond the normal lookahead, only on frames where it finds no trigger (e.g. bass waves longer than a frame). Steadies low-frequency channels without the choppiness of a large always-on lookahead. 0 disables the retry. Empty = use the global track's value (default 3)."
                          kf:Keyframing.PropertyId="TriggerLookaheadOnFailure"
                          kf:Keyframing.Scope="{x:Static kf:KeyframeService+KfScope.Track}"
                          kf:Keyframing.Interpolatable="False"/>

        <TextBlock Text="Shape stability" FontWeight="SemiBold" Margin="0,12,0,4"/>
        <ctrl:TbSliderWpf Margin="2"
                          Value="{Binding ShapeStability, Mode=TwoWay}"
                          Min="0" Max="1" Decimals="2" SmallChange="0.05"
                          AllowEmpty="True"
                          ToolTip="0 = pick the sync point nearest the expected position; higher values prefer the candidate whose surrounding waveform best matches last frame's — steadies complex timbres (synth + reverb) that hop between similar cycles. Only affects candidate-based algorithms (Peak speed, Biggest wave area, Biggest positive area). Empty = use the global track's value (default 0)."
                          kf:Keyframing.PropertyId="ShapeStability"
                          kf:Keyframing.Scope="{x:Static kf:KeyframeService+KfScope.Track}"
                          kf:Keyframing.Interpolatable="True"/>

        <TextBlock Text="Pitch split count" FontWeight="SemiBold" Margin="0,12,0,4"/>
        <ctrl:TbSliderWpf Margin="2"
                          Value="{Binding PitchSplitCount, Mode=TwoWay}"
                          Min="1" Max="4" Decimals="0" SmallChange="1"
                          AllowEmpty="True"
                          ToolTip="Splits the track into up to 4 waveforms by pitch, so chip arpeggios show one stable waveform per pitch instead of one flickering one. 1 = off. Empty = use the global track's value (default 1)."
                          kf:Keyframing.PropertyId="PitchSplitCount"
                          kf:Keyframing.Scope="{x:Static kf:KeyframeService+KfScope.Track}"
                          kf:Keyframing.Interpolatable="False"/>

        <TextBlock Text="Pitch split layout" FontWeight="SemiBold" Margin="0,12,0,4"/>
        <ComboBox Margin="2" SelectedIndex="{Binding PitchSplitLayoutIndex, Mode=TwoWay}"
                  ToolTip="How the split waveforms are arranged. Default = use the global track's setting (whose Default is Stacked)."
                  kf:Keyframing.PropertyId="PitchSplitLayoutIndex"
                  kf:Keyframing.Scope="{x:Static kf:KeyframeService+KfScope.Track}"
                  kf:Keyframing.Interpolatable="False">
            <ComboBoxItem Content="Default"
                          ToolTip="Use the global track's setting. On the global track itself this selects Stacked."/>
            <ComboBoxItem Content="Stacked"
                          ToolTip="Subdivide the track's row into a fixed vertical slice per split waveform."/>
            <ComboBoxItem Content="Overlaid"
                          ToolTip="Draw all split waveforms in the track's row, distinguished by brightness."/>
            <ComboBoxItem Content="Separate"
                          ToolTip="Give each active split waveform its own full-size row, like an independent channel (sharing this track's label and colour)."/>
        </ComboBox>
    </StackPanel>
</UserControl>
