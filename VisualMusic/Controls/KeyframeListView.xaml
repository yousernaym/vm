<UserControl x:Class="VisualMusic.Controls.KeyframeListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="180">
    <DockPanel>
        <DockPanel DockPanel.Dock="Top" Margin="4,4,4,2" LastChildFill="True">
            <!-- Right-aligned action buttons -->
            <Button x:Name="removeBtn" DockPanel.Dock="Right"
                    Width="22" Height="22" Padding="0" Margin="2,0,0,0"
                    IsEnabled="False"
                    ToolTip="Remove selected keyframe(s)"
                    Click="RemoveBtn_Click"
                    Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
            <Button x:Name="addBtn" DockPanel.Dock="Right"
                    Width="22" Height="22" Padding="0" Margin="2,0,0,0"
                    ToolTip="Add empty keyframe at playback position"
                    Click="AddBtn_Click"
                    Content="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
            <TextBlock Text="Keyframes" FontWeight="SemiBold" VerticalAlignment="Center"/>
        </DockPanel>
        <!-- Property filter row: searchable dropdown (TextBox + Popup + ListBox) -->
        <Grid DockPanel.Dock="Top" Margin="4,0,4,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="filterBox" Grid.Column="0"
                     VerticalContentAlignment="Center"
                     GotKeyboardFocus="FilterBox_GotKeyboardFocus"
                     LostKeyboardFocus="FilterBox_LostKeyboardFocus"
                     PreviewMouseLeftButtonDown="FilterBox_PreviewMouseLeftButtonDown"
                     PreviewKeyDown="FilterBox_PreviewKeyDown"
                     TextChanged="FilterBox_TextChanged"/>
            <Button x:Name="clearFilterBtn" Grid.Column="1"
                    Width="22" Height="22" Padding="0" Margin="2,0,0,0"
                    ToolTip="Clear property filter (show all keyframes)"
                    Click="ClearFilterBtn_Click"
                    Content="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="11"/>
            <Popup x:Name="filterPopup" Grid.Column="0"
                   PlacementTarget="{Binding ElementName=filterBox}"
                   Placement="Bottom"
                   StaysOpen="True"
                   AllowsTransparency="True"
                   Width="{Binding ActualWidth, ElementName=filterBox}">
                <Border Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                        BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                        BorderThickness="1">
                    <ListBox x:Name="filterList"
                             ItemsSource="{Binding Properties}"
                             DisplayMemberPath="Display"
                             MaxHeight="240"
                             Focusable="False"
                             PreviewMouseLeftButtonUp="FilterList_PreviewMouseLeftButtonUp">
                        <ListBox.Resources>
                            <!-- Keep the highlight visible even though keyboard focus stays in the search box -->
                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#FF3399FF"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="White"/>
                        </ListBox.Resources>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Focusable" Value="False"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Border>
            </Popup>
        </Grid>
        <DataGrid x:Name="grid"
                  ItemsSource="{Binding Rows}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="False"
                  CanUserResizeRows="False"
                  SelectionMode="Extended"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  BorderThickness="0"
                  CellEditEnding="Grid_CellEditEnding"
                  SelectionChanged="Grid_SelectionChanged"
                  PreviewKeyDown="Grid_PreviewKeyDown"
                  ContextMenuOpening="Grid_ContextMenuOpening">
            <DataGrid.ContextMenu>
                <ContextMenu/>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Beat"
                                    Binding="{Binding TimeDisplay, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                    Width="55"
                                    IsReadOnly="False"/>
                <DataGridTextColumn Header="Description"
                                    Binding="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                    Width="*"/>
                <DataGridTextColumn Header="#"
                                    Binding="{Binding PropertyCount, Mode=OneWay}"
                                    Width="30"
                                    IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
