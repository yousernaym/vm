<mah:MetroWindow x:Class="VisualMusic.Forms.HueSatWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:ctrl="clr-namespace:VisualMusic.Controls"
                 Title="Color"
                 Width="320" Height="280"
                 ResizeMode="NoResize"
                 WindowStartupLocation="CenterOwner"
                 ShowMinButton="False" ShowMaxRestoreButton="False">
    <DockPanel Margin="8">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="OK"     Width="72" IsDefault="True"  Click="OkBtn_Click" Margin="0,0,4,0"/>
            <Button Content="Cancel" Width="72" IsCancel="True"   Click="CancelBtn_Click"/>
        </StackPanel>
        <ctrl:TwoDHueSatWpf x:Name="picker"
                             SelectionChanged="Picker_SelectionChanged"/>
    </DockPanel>
</mah:MetroWindow>
