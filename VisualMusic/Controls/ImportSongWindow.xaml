<mah:MetroWindow x:Class="VisualMusic.Controls.ImportSongWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 Title="{Binding Title}"
                 ResizeMode="NoResize"
                 SizeToContent="WidthAndHeight"
                 WindowStartupLocation="CenterOwner"
                 ShowMinButton="False"
                 ShowMaxRestoreButton="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Note file row -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="Song file:" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" x:Name="noteFileBox" Text="{Binding NoteFilePath, UpdateSourceTrigger=PropertyChanged}"
                     VerticalAlignment="Center"/>
            <Button Grid.Column="3" Content="Browse..." Click="BrowseNote_Click" VerticalAlignment="Center"/>
        </Grid>

        <!-- Audio file row -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="{Binding AudioLabel}" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Text="{Binding AudioFilePath, UpdateSourceTrigger=PropertyChanged}"
                     VerticalAlignment="Center"/>
            <Button Grid.Column="3" Content="Browse..." Click="BrowseAudio_Click" VerticalAlignment="Center"/>
        </Grid>

        <!-- Options -->
        <StackPanel Grid.Row="4" Orientation="Vertical">
            <CheckBox Content="Erase current project" IsChecked="{Binding EraseCurrent}" Margin="0,0,0,6"/>
            <CheckBox Content="Insert track (keep existing tracks)" IsChecked="{Binding InsTrack}"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK"     Width="80" IsDefault="True"  Click="Ok_Click" Margin="0,0,8,0"/>
            <Button Content="Cancel" Width="80" IsCancel="True"   Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</mah:MetroWindow>
