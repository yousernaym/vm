<UserControl x:Class="VisualMusic.Controls.KeyframeListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="180">
    <DockPanel>
        <TextBlock DockPanel.Dock="Top"
                   Text="Keyframes"
                   FontWeight="SemiBold"
                   Margin="4,4,4,2"/>
        <DataGrid x:Name="grid"
                  ItemsSource="{Binding Rows}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="False"
                  CanUserResizeRows="False"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  BorderThickness="0"
                  CellEditEnding="Grid_CellEditEnding"
                  SelectionChanged="Grid_SelectionChanged"
                  PreviewKeyDown="Grid_PreviewKeyDown">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Time"
                                    Binding="{Binding TimeDisplay, Mode=OneWay}"
                                    Width="70"
                                    IsReadOnly="False"/>
                <DataGridTextColumn Header="Description"
                                    Binding="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                    Width="*"/>
                <DataGridTextColumn Header="#"
                                    Binding="{Binding PropertyCount, Mode=OneWay}"
                                    Width="30"
                                    IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
