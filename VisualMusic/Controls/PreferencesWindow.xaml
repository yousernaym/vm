<mah:MetroWindow x:Class="VisualMusic.Controls.PreferencesWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 Title="Preferences"
                 ResizeMode="NoResize"
                 SizeToContent="WidthAndHeight"
                 WindowStartupLocation="CenterOwner"
                 ShowMinButton="False"
                 ShowMaxRestoreButton="False">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Theme section header -->
        <TextBlock Grid.Row="0" Text="Theme" FontWeight="Bold"/>

        <!-- Base color + accent color dropdowns -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="180"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Base color:" VerticalAlignment="Center"/>
            <ComboBox  Grid.Column="1"
                       ItemsSource="{Binding BaseColors}"
                       SelectedItem="{Binding SelectedBaseColor, Mode=TwoWay}"
                       VerticalAlignment="Center"/>

            <TextBlock Grid.Column="3" Text="Accent color:" VerticalAlignment="Center"/>
            <ComboBox  Grid.Column="4"
                       ItemsSource="{Binding ColorSchemes}"
                       SelectedItem="{Binding SelectedColorScheme, Mode=TwoWay}"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- Preview label -->
        <TextBlock Grid.Row="4" Text="Changes are previewed live. Cancel reverts." Foreground="Gray" FontStyle="Italic"/>

        <!-- OK / Cancel -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK"     Width="80" IsDefault="True"  Click="Ok_Click"     Margin="0,0,8,0"/>
            <Button Content="Cancel" Width="80" IsCancel="True"   Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</mah:MetroWindow>
