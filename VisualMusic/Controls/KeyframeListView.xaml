<UserControl x:Class="VisualMusic.Controls.KeyframeListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="180">
    <DockPanel>
        <DockPanel DockPanel.Dock="Top" Margin="4,4,4,2" LastChildFill="True">
            <!-- Right-aligned action buttons -->
            <Button x:Name="removeBtn" DockPanel.Dock="Right"
                    Width="22" Height="22" Padding="0" Margin="2,0,0,0"
                    ToolTip="Remove selected keyframe"
                    Click="RemoveBtn_Click"
                    Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
            <Button x:Name="addBtn" DockPanel.Dock="Right"
                    Width="22" Height="22" Padding="0" Margin="2,0,0,0"
                    ToolTip="Add empty keyframe at playback position"
                    Click="AddBtn_Click"
                    Content="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
            <TextBlock Text="Keyframes" FontWeight="SemiBold" VerticalAlignment="Center"/>
        </DockPanel>
        <DataGrid x:Name="grid"
                  ItemsSource="{Binding Rows}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="False"
                  CanUserResizeRows="False"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  BorderThickness="0"
                  CellEditEnding="Grid_CellEditEnding"
                  SelectionChanged="Grid_SelectionChanged"
                  PreviewKeyDown="Grid_PreviewKeyDown"
                  ContextMenuOpening="Grid_ContextMenuOpening">
            <DataGrid.ContextMenu>
                <ContextMenu/>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Beat"
                                    Binding="{Binding TimeDisplay, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                    Width="55"
                                    IsReadOnly="False"/>
                <DataGridTextColumn Header="Description"
                                    Binding="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                    Width="*"/>
                <DataGridTextColumn Header="#"
                                    Binding="{Binding PropertyCount, Mode=OneWay}"
                                    Width="30"
                                    IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
