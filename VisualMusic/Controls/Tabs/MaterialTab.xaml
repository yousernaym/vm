<UserControl x:Class="VisualMusic.Controls.Tabs.MaterialTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:VisualMusic.Controls">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="4">

            <Button Content="Default Material" HorizontalAlignment="Left"
                    Margin="0,0,0,6" Click="DefaultMaterialBtn_Click"/>

            <!-- Color -->
            <TextBlock Text="Color" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Transparency:" VerticalAlignment="Center" Margin="0,1"/>
                <ctrl:TbSliderWpf Grid.Row="0" Grid.Column="1" Margin="2"
                                  Value="{Binding Transp, Mode=TwoWay}" Min="0" Max="1" Decimals="2"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Hue:" VerticalAlignment="Center" Margin="0,1"/>
                <ctrl:TbSliderWpf Grid.Row="1" Grid.Column="1" Margin="2"
                                  Value="{Binding MaterialHue, Mode=TwoWay}" Min="0" Max="1" Decimals="2"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Normal sat:" VerticalAlignment="Center" Margin="0,1"/>
                <ctrl:TbSliderWpf Grid.Row="2" Grid.Column="1" Margin="2"
                                  Value="{Binding NormalSat, Mode=TwoWay}" Min="0" Max="2" Decimals="2"/>
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Normal lum:" VerticalAlignment="Center" Margin="0,1"/>
                <ctrl:TbSliderWpf Grid.Row="3" Grid.Column="1" Margin="2"
                                  Value="{Binding NormalLum, Mode=TwoWay}" Min="0" Max="4" Decimals="2"/>
                <TextBlock Grid.Row="4" Grid.Column="0" Text="Hilite sat:" VerticalAlignment="Center" Margin="0,1"/>
                <ctrl:TbSliderWpf Grid.Row="4" Grid.Column="1" Margin="2"
                                  Value="{Binding HiliteSat, Mode=TwoWay}" Min="0" Max="2" Decimals="2"/>
                <TextBlock Grid.Row="5" Grid.Column="0" Text="Hilite lum:" VerticalAlignment="Center" Margin="0,1"/>
                <ctrl:TbSliderWpf Grid.Row="5" Grid.Column="1" Margin="2"
                                  Value="{Binding HiliteLum, Mode=TwoWay}" Min="0" Max="4" Decimals="2"/>
            </Grid>

            <Separator Margin="0,6,0,6"/>

            <!-- Texture -->
            <TextBlock Text="Texture" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <Image x:Name="texThumb" Source="{Binding TextureThumbnail}"
                   Height="64" Stretch="Uniform"
                   HorizontalAlignment="Left" Margin="0,0,0,4"/>
            <TextBlock Text="{Binding TexturePath}" TextTrimming="CharacterEllipsis"
                       Margin="0,0,0,4" FontSize="10"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <Button Content="Load..."   Width="56" Margin="0,0,4,0" Click="LoadTexBtn_Click"/>
                <Button Content="Unload"    Width="56" Click="UnloadTexBtn_Click"/>
            </StackPanel>

            <WrapPanel>
                <CheckBox Content="Disable"    IsChecked="{Binding DisableTexture, Mode=TwoWay}" IsThreeState="True" Margin="0,0,6,2"/>
                <CheckBox Content="Point smp"  IsChecked="{Binding PointSmp,       Mode=TwoWay}" IsThreeState="True" Margin="0,0,6,2"/>
                <CheckBox Content="Blend col"  IsChecked="{Binding TexColBlend,    Mode=TwoWay}" IsThreeState="True" Margin="0,0,6,2"/>
                <CheckBox Content="U tile"     IsChecked="{Binding UTile,          Mode=TwoWay}" IsThreeState="True" Margin="0,0,6,2"/>
                <CheckBox Content="V tile"     IsChecked="{Binding VTile,          Mode=TwoWay}" IsThreeState="True" Margin="0,0,6,2"/>
                <CheckBox Content="Keep aspect" IsChecked="{Binding KeepAspect,    Mode=TwoWay}" IsThreeState="True" Margin="0,0,6,2"/>
            </WrapPanel>

            <StackPanel Margin="0,6,0,0">
                <TextBlock Text="U anchor:" Margin="0,0,0,2"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <RadioButton Content="Note"   IsChecked="{Binding UAnchorNote,   Mode=TwoWay}" Margin="0,0,6,0"/>
                    <RadioButton Content="Screen" IsChecked="{Binding UAnchorScreen, Mode=TwoWay}" Margin="0,0,6,0"/>
                    <RadioButton Content="Song"   IsChecked="{Binding UAnchorSong,   Mode=TwoWay}"/>
                </StackPanel>
                <TextBlock Text="V anchor:" Margin="0,0,0,2"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <RadioButton Content="Note"   IsChecked="{Binding VAnchorNote,   Mode=TwoWay}" Margin="0,0,6,0"/>
                    <RadioButton Content="Screen" IsChecked="{Binding VAnchorScreen, Mode=TwoWay}" Margin="0,0,6,0"/>
                </StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="U scroll:" VerticalAlignment="Center" Margin="0,2"/>
                    <ctrl:TbSliderWpf Grid.Row="0" Grid.Column="1" Margin="2"
                                      Value="{Binding UScroll, Mode=TwoWay}"
                                      Min="-1" Max="1" Decimals="3" SmallChange="0.005"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="V scroll:" VerticalAlignment="Center" Margin="0,2"/>
                    <ctrl:TbSliderWpf Grid.Row="1" Grid.Column="1" Margin="2"
                                      Value="{Binding VScroll, Mode=TwoWay}"
                                      Min="-1" Max="1" Decimals="3" SmallChange="0.005"/>
                </Grid>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
