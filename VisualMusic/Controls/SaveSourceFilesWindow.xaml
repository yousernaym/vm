<mah:MetroWindow x:Class="VisualMusic.Controls.SaveSourceFilesWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 Title="Save source files"
                 ResizeMode="NoResize"
                 SizeToContent="WidthAndHeight"
                 WindowStartupLocation="CenterOwner"
                 ShowMinButton="False"
                 ShowMaxRestoreButton="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Also save the converted files alongside the project?"
                   MaxWidth="320" TextWrapping="Wrap"/>

        <!-- Options -->
        <StackPanel Grid.Row="2" Orientation="Vertical">
            <CheckBox Content="Save MIDI file" IsChecked="{Binding SaveMidi}"
                      IsEnabled="{Binding MidiAvailable}" Margin="0,0,0,8"/>
            <CheckBox Content="Save WAV file" IsChecked="{Binding SaveWav}"
                      IsEnabled="{Binding WavAvailable}"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK"     Width="80" IsDefault="True"  Click="Ok_Click" Margin="0,0,8,0"/>
            <Button Content="Cancel" Width="80" IsCancel="True"   Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</mah:MetroWindow>
