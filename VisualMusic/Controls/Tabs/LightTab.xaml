<UserControl x:Class="VisualMusic.Controls.Tabs.LightTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:VisualMusic.Controls"
             xmlns:kf="clr-namespace:VisualMusic.Keyframes">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="4">
            <Button Content="_Default Light" HorizontalAlignment="Left"
                    Margin="0,0,0,6" Click="DefaultLightBtn_Click"/>
            <CheckBox Content="Use global light"
                      IsChecked="{Binding UseGlobalLight, Mode=TwoWay}"
                      IsThreeState="True" Margin="0,0,0,6"
                      kf:Keyframing.PropertyId="UseGlobalLight"
                      kf:Keyframing.Scope="{x:Static kf:KeyframeService+KfScope.Track}"
                      kf:Keyframing.Interpolatable="False"/>

            <!-- Direction -->
            <TextBlock Text="Direction" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="X" VerticalAlignment="Center"/>
                <ctrl:TbSliderWpf Grid.Row="0" Grid.Column="1" Margin="2"
                                  Value="{Binding LightDirX, Mode=TwoWay}" Min="-10" Max="10" Decimals="2"
                                  kf:Keyframing.PropertyId="LightDirX"
                                  kf:Keyframing.Scope="{x:Static kf:KeyframeService+KfScope.Track}"
                                  kf:Keyframing.Interpolatable="True"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Y" VerticalAlignment="Center"/>
                <ctrl:TbSliderWpf Grid.Row="1" Grid.Column="1" Margin="2"
                                  Value="{Binding LightDirY, Mode=TwoWay}" Min="-10" Max="10" Decimals="2"
                                  kf:Keyframing.PropertyId="LightDirY"
                                  kf:Keyframing.Scope="{x:Static kf:KeyframeService+KfScope.Track}"
                                  kf:Keyframing.Interpolatable="True"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Z" VerticalAlignment="Center"/>
                <ctrl:TbSliderWpf Grid.Row="2" Grid.Column="1" Margin="2"
                                  Value="{Binding LightDirZ, Mode=TwoWay}" Min="-10" Max="10" Decimals="2"
                                  kf:Keyframing.PropertyId="LightDirZ"
                                  kf:Keyframing.Scope="{x:Static kf:KeyframeService+KfScope.Track}"
                                  kf:Keyframing.Interpolatable="True"/>
            </Grid>

            <Separator Margin="0,6,0,6"/>

            <!-- Ambient -->
            <TextBlock Text="Ambient" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Amount:" VerticalAlignment="Center"/>
                <ctrl:TbSliderWpf Grid.Column="1" Margin="2"
                                  Value="{Binding AmbientAmount, Mode=TwoWay}" Min="0" Max="5" Decimals="2"
                                  kf:Keyframing.PropertyId="AmbientAmount"
                                  kf:Keyframing.Scope="{x:Static kf:KeyframeService+KfScope.Track}"
                                  kf:Keyframing.Interpolatable="True"/>
                <ctrl:HueSatButtonWpf Grid.Column="2" Margin="2"
                                      SelectedXnaColor="{Binding AmbientXnaColor, Mode=TwoWay}"
                                      kf:Keyframing.PropertyId="AmbientColor"
                                      kf:Keyframing.Scope="{x:Static kf:KeyframeService+KfScope.Track}"
                                      kf:Keyframing.Interpolatable="True"/>
            </Grid>

            <!-- Diffuse -->
            <TextBlock Text="Diffuse" FontWeight="SemiBold" Margin="0,6,0,4"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Amount:" VerticalAlignment="Center"/>
                <ctrl:TbSliderWpf Grid.Column="1" Margin="2"
                                  Value="{Binding DiffuseAmount, Mode=TwoWay}" Min="0" Max="10" Decimals="2"
                                  kf:Keyframing.PropertyId="DiffuseAmount"
                                  kf:Keyframing.Scope="{x:Static kf:KeyframeService+KfScope.Track}"
                                  kf:Keyframing.Interpolatable="True"/>
                <ctrl:HueSatButtonWpf Grid.Column="2" Margin="2"
                                      SelectedXnaColor="{Binding DiffuseXnaColor, Mode=TwoWay}"
                                      kf:Keyframing.PropertyId="DiffuseColor"
                                      kf:Keyframing.Scope="{x:Static kf:KeyframeService+KfScope.Track}"
                                      kf:Keyframing.Interpolatable="True"/>
            </Grid>

            <!-- Specular -->
            <TextBlock Text="Specular" FontWeight="SemiBold" Margin="0,6,0,4"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Amount:" VerticalAlignment="Center"/>
                <ctrl:TbSliderWpf Grid.Row="0" Grid.Column="1" Margin="2"
                                  Value="{Binding SpecAmount, Mode=TwoWay}" Min="0" Max="10" Decimals="2"
                                  kf:Keyframing.PropertyId="SpecAmount"
                                  kf:Keyframing.Scope="{x:Static kf:KeyframeService+KfScope.Track}"
                                  kf:Keyframing.Interpolatable="True"/>
                <ctrl:HueSatButtonWpf Grid.Row="0" Grid.Column="2" Margin="2"
                                      SelectedXnaColor="{Binding SpecXnaColor, Mode=TwoWay}"
                                      kf:Keyframing.PropertyId="SpecColor"
                                      kf:Keyframing.Scope="{x:Static kf:KeyframeService+KfScope.Track}"
                                      kf:Keyframing.Interpolatable="True"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Power:" VerticalAlignment="Center"/>
                <ctrl:TbSliderWpf Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="2"
                                  Value="{Binding SpecPower, Mode=TwoWay}" Min="1" Max="200" Decimals="0"
                                  kf:Keyframing.PropertyId="SpecPower"
                                  kf:Keyframing.Scope="{x:Static kf:KeyframeService+KfScope.Track}"
                                  kf:Keyframing.Interpolatable="True"/>
            </Grid>

            <!-- Master -->
            <TextBlock Text="Master" FontWeight="SemiBold" Margin="0,6,0,4"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Amount:" VerticalAlignment="Center"/>
                <ctrl:TbSliderWpf Grid.Column="1" Margin="2"
                                  Value="{Binding MasterAmount, Mode=TwoWay}" Min="0" Max="5" Decimals="2"
                                  kf:Keyframing.PropertyId="MasterAmount"
                                  kf:Keyframing.Scope="{x:Static kf:KeyframeService+KfScope.Track}"
                                  kf:Keyframing.Interpolatable="True"/>
                <ctrl:HueSatButtonWpf Grid.Column="2" Margin="2"
                                      SelectedXnaColor="{Binding MasterXnaColor, Mode=TwoWay}"
                                      kf:Keyframing.PropertyId="MasterColor"
                                      kf:Keyframing.Scope="{x:Static kf:KeyframeService+KfScope.Track}"
                                      kf:Keyframing.Interpolatable="True"/>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
