<UserControl x:Class="VisualMusic.Controls.Tabs.SpatialTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:VisualMusic.Controls"
             xmlns:kf="clr-namespace:VisualMusic.Keyframes">
    <StackPanel Margin="4">
        <Button Content="_Default Spatial" HorizontalAlignment="Left"
                Margin="0,0,0,6" Click="DefaultSpatialBtn_Click"/>
        <TextBlock Text="Position offset" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" Text="X" VerticalAlignment="Center"/>
            <ctrl:TbSliderWpf Grid.Row="0" Grid.Column="1" Margin="2"
                              Value="{Binding XOffset, Mode=TwoWay}" Min="-1000" Max="1000" Decimals="2" SmallChange="1"
                              kf:Keyframing.PropertyId="XOffset"
                              kf:Keyframing.Scope="{x:Static kf:KeyframeService+KfScope.Track}"
                              kf:Keyframing.Interpolatable="True"/>
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Y" VerticalAlignment="Center"/>
            <ctrl:TbSliderWpf Grid.Row="1" Grid.Column="1" Margin="2"
                              Value="{Binding YOffset, Mode=TwoWay}" Min="-1000" Max="1000" Decimals="2" SmallChange="1"
                              kf:Keyframing.PropertyId="YOffset"
                              kf:Keyframing.Scope="{x:Static kf:KeyframeService+KfScope.Track}"
                              kf:Keyframing.Interpolatable="True"/>
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Z" VerticalAlignment="Center"/>
            <ctrl:TbSliderWpf Grid.Row="2" Grid.Column="1" Margin="2"
                              Value="{Binding ZOffset, Mode=TwoWay}" Min="-1000" Max="1000" Decimals="2" SmallChange="1"
                              kf:Keyframing.PropertyId="ZOffset"
                              kf:Keyframing.Scope="{x:Static kf:KeyframeService+KfScope.Track}"
                              kf:Keyframing.Interpolatable="True"/>
        </Grid>
        <TextBlock Text="Pitch offset" FontWeight="SemiBold" Margin="0,6,0,4"/>
        <ctrl:TbSliderWpf Margin="2"
                          Value="{Binding PitchOffset, Mode=TwoWay}" Min="-127" Max="127" Decimals="2" SmallChange="1"
                          kf:Keyframing.PropertyId="PitchOffset"
                          kf:Keyframing.Scope="{x:Static kf:KeyframeService+KfScope.Track}"
                          kf:Keyframing.Interpolatable="True"/>
        <TextBlock Text="Viewport width" FontWeight="SemiBold" Margin="0,6,0,4"/>
        <ctrl:TbSliderWpf Margin="2"
                          Value="{Binding ViewWidthQn, Mode=TwoWay}"
                          Min="0" Max="10" ExpBase="2" Decimals="3" Decimals2="2"
                          AllowEmpty="True"
                          ToolTip="Quarter notes visible per screen. Empty = use the global track's value."
                          CommitChanges="ViewWidth_CommitChanges"
                          kf:Keyframing.PropertyId="ViewWidthQn"
                          kf:Keyframing.Scope="{x:Static kf:KeyframeService+KfScope.Track}"
                          kf:Keyframing.Interpolatable="True"/>
    </StackPanel>
</UserControl>
