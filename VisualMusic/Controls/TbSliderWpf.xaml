<UserControl x:Class="VisualMusic.Controls.TbSliderWpf"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Slider x:Name="slider" Grid.Column="0"
                Minimum="{Binding Min, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Maximum="{Binding Max, RelativeSource={RelativeSource AncestorType=UserControl}}"
                VerticalAlignment="Center"
                SmallChange="0.01"
                IsSnapToTickEnabled="False"
                ValueChanged="Slider_ValueChanged"
                PreviewMouseUp="Slider_MouseUp"
                KeyDown="Slider_KeyDown"/>
        <TextBox x:Name="textBox" Grid.Column="1" Width="52"
                 VerticalContentAlignment="Center"
                 TextChanged="TextBox_TextChanged"
                 KeyDown="TextBox_KeyDown"
                 LostFocus="TextBox_LostFocus"
                 Margin="2,0,0,0"/>
    </Grid>
</UserControl>
