<mah:MetroWindow x:Class="VisualMusic.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:ctrl="clr-namespace:VisualMusic.Controls"
                 xmlns:conv="clr-namespace:VisualMusic.Converters"
                 xmlns:local="clr-namespace:VisualMusic"
                 Title="{Binding WindowTitle}"
                 Height="800" Width="1200"
                 WindowStartupLocation="CenterScreen"
                 PreviewKeyDown="Window_PreviewKeyDown">
    <mah:MetroWindow.Resources>
        <conv:EqualityToVisibilityConverter x:Key="ScreenVis"/>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
    </mah:MetroWindow.Resources>

    <!-- Keyboard bindings -->
    <mah:MetroWindow.InputBindings>
        <!-- File -->
        <KeyBinding Command="{Binding ImportMidiCommand}"     Key="M"    Modifiers="Control"/>
        <KeyBinding Command="{Binding ImportModCommand}"      Key="M"    Modifiers="Control+Shift"/>
        <KeyBinding Command="{Binding ImportHvlCommand}"      Key="H"    Modifiers="Control"/>
        <KeyBinding Command="{Binding ImportSidCommand}"      Key="S"    Modifiers="Control+Shift"/>
        <KeyBinding Command="{Binding OpenProjectCommand}"    Key="O"    Modifiers="Control"/>
        <KeyBinding Command="{Binding SaveProjectCommand}"    Key="S"    Modifiers="Control"/>
        <KeyBinding Command="{Binding SaveProjectAsCommand}"  Key="S"    Modifiers="Alt+Shift"/>
        <KeyBinding Command="{Binding ExportVideoCommand}"    Key="E"    Modifiers="Control"/>
        <!-- Edit -->
        <KeyBinding Command="{Binding UndoCommand}"           Key="Z"    Modifiers="Control"/>
        <KeyBinding Command="{Binding RedoCommand}"           Key="Z"    Modifiers="Control+Shift"/>
        <KeyBinding Command="{Binding ResetCameraCommand}"    Key="R"    Modifiers="Control"/>
        <KeyBinding Command="{Binding DefaultTrackPropsCommand}" Key="D" Modifiers="Control"/>
        <KeyBinding Command="{Binding LoadTrackPropsCommand}" Key="T"    Modifiers="Control"/>
        <KeyBinding Command="{Binding SaveTrackPropsCommand}" Key="T"    Modifiers="Control+Shift"/>
        <KeyBinding Command="{Binding InsertLyricsCommand}"   Key="L"    Modifiers="Control"/>
        <KeyBinding Command="{Binding SettingsCommand}"       Key="F12"/>
        <!-- Playback — Ctrl+Space handled via PreviewKeyDown in code-behind (tunneling) so it
             fires even when a focused panel control (CheckBox, ListBox, etc.) would otherwise
             swallow the Space activation key. -->
        <KeyBinding Command="{Binding GoToBeginningCommand}"     Key="Home"   Modifiers="Control"/>
        <KeyBinding Command="{Binding GoToEndCommand}"           Key="End"    Modifiers="Control"/>
        <KeyBinding Command="{Binding NudgeBackCommand}"         Key="Left"   Modifiers="Control"/>
        <KeyBinding Command="{Binding NudgeForwardCommand}"      Key="Right"  Modifiers="Control"/>
        <KeyBinding Command="{Binding JumpBackCommand}"          Key="Left"   Modifiers="Control+Shift"/>
        <KeyBinding Command="{Binding JumpForwardCommand}"       Key="Right"  Modifiers="Control+Shift"/>
        <!-- Keyframe navigation -->
        <KeyBinding Command="{Binding GoToNextKeyFrameCommand}"  Key="OemPeriod"  Modifiers="Control"/>
        <KeyBinding Command="{Binding GoToPrevKeyFrameCommand}"  Key="OemComma"   Modifiers="Control"/>
        <!-- View -->
        <KeyBinding Command="{Binding ShowSongCommand}"       Key="F1"/>
        <KeyBinding Command="{Binding ShowModBrowserCommand}" Key="F2"/>
        <KeyBinding Command="{Binding ShowSidBrowserCommand}" Key="F3"/>
        <KeyBinding Command="{Binding ShowMidiBrowserCommand}" Key="F4"/>
    </mah:MetroWindow.InputBindings>

    <DockPanel>
        <!-- Top row: menu + panel toggle buttons share one dock slot -->
        <DockPanel DockPanel.Dock="Top">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="0,0,8,0"
                        IsEnabled="{Binding HasProject}">
                <ToggleButton Content="Pr_oject properties"
                              IsChecked="{Binding ShowSongProps, Mode=TwoWay}"
                              Margin="2,1" Padding="4,1"/>
                <ToggleButton Content="_Track properties"
                              IsChecked="{Binding ShowTrackProps, Mode=TwoWay}"
                              Margin="2,1" Padding="4,1"/>
            </StackPanel>

            <!-- Mouse-look mode indicator — yellow label, visible only while mode is active -->
            <TextBlock DockPanel.Dock="Right"
                       Text="MOUSE LOOK"
                       Foreground="Yellow" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="8,0"
                       Visibility="{Binding IsMouseLookMode, Converter={StaticResource BoolVis}}"/>

        <!-- Menu bar -->
        <Menu>

            <!-- FILE -->
            <MenuItem Header="_File">
                <MenuItem Header="Import _MIDI song..."   Command="{Binding ImportMidiCommand}"    InputGestureText="Ctrl+M"/>
                <MenuItem Header="Import M_odule..."      Command="{Binding ImportModCommand}"     InputGestureText="Ctrl+Shift+M"/>
                <MenuItem Header="Import _HVL song..."    Command="{Binding ImportHvlCommand}"     InputGestureText="Ctrl+H"/>
                <MenuItem Header="Import _SID song..."    Command="{Binding ImportSidCommand}"     InputGestureText="Ctrl+Shift+S"/>
                <MenuItem Header="Import _audio..."        Command="{Binding ImportAudioCommand}"/>
                <Separator/>
                <MenuItem Header="_Open project..."       Command="{Binding OpenProjectCommand}"   InputGestureText="Ctrl+O"/>
                <MenuItem Header="_Save project"          Command="{Binding SaveProjectCommand}"   InputGestureText="Ctrl+S"/>
                <MenuItem Header="Save project _as..."    Command="{Binding SaveProjectAsCommand}" InputGestureText="Alt+Shift+S"/>
                <Separator/>
                <MenuItem Header="_Export video..."       Command="{Binding ExportVideoCommand}"   InputGestureText="Ctrl+E"/>
            </MenuItem>

            <!-- EDIT -->
            <MenuItem Header="_Edit">
                <MenuItem Header="{Binding UndoMenuHeader}" Command="{Binding UndoCommand}"  InputGestureText="Ctrl+Z"/>
                <MenuItem Header="{Binding RedoMenuHeader}" Command="{Binding RedoCommand}"  InputGestureText="Ctrl+Shift+Z"/>
                <Separator/>
                <MenuItem Header="_Camera">
                    <MenuItem Header="_Reset"  Command="{Binding ResetCameraCommand}" InputGestureText="Ctrl+R"/>
                    <MenuItem Header="_Load..."  Command="{Binding LoadCameraCommand}"/>
                    <MenuItem Header="_Save..."  Command="{Binding SaveCameraCommand}"/>
                </MenuItem>
                <MenuItem Header="_Tracks">
                    <MenuItem Header="_Load properties..."  Command="{Binding LoadTrackPropsCommand}"   InputGestureText="Ctrl+T"/>
                    <MenuItem Header="_Save properties..."  Command="{Binding SaveTrackPropsCommand}"   InputGestureText="Ctrl+Shift+T"/>
                    <MenuItem Header="_Default Properties" Command="{Binding DefaultTrackPropsCommand}" InputGestureText="Ctrl+D"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Insert _Lyrics"    Command="{Binding InsertLyricsCommand}"   InputGestureText="Ctrl+L"/>
                <Separator/>
                <MenuItem Header="_Settings..."   Command="{Binding SettingsCommand}" InputGestureText="F12"/>
            </MenuItem>

            <!-- PLAYBACK -->
            <MenuItem Header="_Playback">
                <MenuItem Header="_Start/Stop"      Command="{Binding TogglePlaybackCommand}" InputGestureText="Ctrl+Space"/>
                <MenuItem Header="Go to _beginning" Command="{Binding GoToBeginningCommand}"  InputGestureText="Ctrl+Home"/>
                <MenuItem Header="Go to _end"       Command="{Binding GoToEndCommand}"        InputGestureText="Ctrl+End"/>
                <Separator/>
                <MenuItem Header="Nudge _backwards" Command="{Binding NudgeBackCommand}"    InputGestureText="Ctrl+Left"/>
                <MenuItem Header="Nudge _forwards"  Command="{Binding NudgeForwardCommand}" InputGestureText="Ctrl+Right"/>
                <MenuItem Header="Jump b_ackwards"  Command="{Binding JumpBackCommand}"     InputGestureText="Ctrl+Shift+Left"/>
                <MenuItem Header="Jump fo_rwards"   Command="{Binding JumpForwardCommand}"  InputGestureText="Ctrl+Shift+Right"/>
                <Separator/>
                <MenuItem Header="Go to _next keyframe"     Command="{Binding GoToNextKeyFrameCommand}" InputGestureText="Ctrl+."/>
                <MenuItem Header="Go to _previous keyframe" Command="{Binding GoToPrevKeyFrameCommand}" InputGestureText="Ctrl+,"/>
            </MenuItem>

            <!-- VIEW -->
            <MenuItem Header="_View">
                <MenuItem Header="_Song"         Command="{Binding ShowSongCommand}"       InputGestureText="F1"/>
                <MenuItem Header="_Mod browser"  Command="{Binding ShowModBrowserCommand}" InputGestureText="F2"/>
                <MenuItem Header="S_ID browser"  Command="{Binding ShowSidBrowserCommand}" InputGestureText="F3"/>
                <MenuItem Header="M_IDI browser" Command="{Binding ShowMidiBrowserCommand}" InputGestureText="F4"/>
            </MenuItem>
        </Menu>
        </DockPanel>

        <!-- Left: keyframe list + project properties (shown/hidden together) -->
        <DockPanel DockPanel.Dock="Left"
                   Visibility="{Binding ShowSongProps, Converter={StaticResource BoolVis}}">
            <ctrl:KeyframeListView x:Name="keyframeListView"
                                   DockPanel.Dock="Left" Width="200"/>
            <ctrl:SongPropsPanel DockPanel.Dock="Left" Width="216"
                                 DataContext="{Binding SongProps}"/>
        </DockPanel>

        <!-- Right: track list (with splitter) + property tabs -->
        <Grid DockPanel.Dock="Right" Width="395"
              Visibility="{Binding ShowTrackProps,
                           Converter={StaticResource BoolVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="186" MinWidth="120"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*" MinWidth="180"/>
            </Grid.ColumnDefinitions>
            <ctrl:TrackListView  x:Name="trackListControl" Grid.Column="0" DataContext="{Binding TrackList}"/>
            <GridSplitter        Grid.Column="1" HorizontalAlignment="Stretch" Width="4"/>
            <ctrl:TrackPropsView Grid.Column="2" DataContext="{Binding SelectedTrackProps}"/>
        </Grid>

        <!-- Center (LastChildFill): keyframe strip + scrollbar + MonoGame + browser screens -->
        <DockPanel>
            <!-- Keyframe diamond strip — thin black panel above the render surface.
                 Must come before the Grid (LastChildFill) so it's docked Top.
                 Only shown on the Song screen. -->
            <ctrl:KeyframePanel DockPanel.Dock="Top"
                                Visibility="{Binding CurrentScreen,
                                             Converter={StaticResource ScreenVis},
                                             ConverterParameter=Song}"/>

            <!-- Timeline scrollbar at bottom, confined to center column only -->
            <ScrollBar DockPanel.Dock="Bottom" Orientation="Horizontal"
                       Minimum="0" Maximum="1"
                       SmallChange="0.0625" LargeChange="1.0"
                       Value="{Binding ScrollPosition, Mode=TwoWay}"
                       IsEnabled="{Binding HasProject}"
                       Visibility="{Binding CurrentScreen,
                                    Converter={StaticResource ScreenVis},
                                    ConverterParameter=Song}"/>
            <Grid>
                <!-- MonoGame render surface — visible on Song screen -->
                <local:MonoGameHost x:Name="monoGameHost"
                    Visibility="{Binding CurrentScreen, Converter={StaticResource ScreenVis}, ConverterParameter=Song}"/>

                <!-- MOD Archive browser -->
                <ctrl:SongWebBrowserWpf x:Name="modBrowser"
                    Visibility="{Binding CurrentScreen, Converter={StaticResource ScreenVis}, ConverterParameter=ModBrowser}"/>

                <!-- HVSC / SID browser -->
                <ctrl:SongWebBrowserWpf x:Name="sidBrowser"
                    Visibility="{Binding CurrentScreen, Converter={StaticResource ScreenVis}, ConverterParameter=SidBrowser}"/>

                <!-- BitMidi browser -->
                <ctrl:SongWebBrowserWpf x:Name="midiBrowser"
                    Visibility="{Binding CurrentScreen, Converter={StaticResource ScreenVis}, ConverterParameter=MidiBrowser}"/>
            </Grid>
        </DockPanel>
    </DockPanel>
</mah:MetroWindow>
